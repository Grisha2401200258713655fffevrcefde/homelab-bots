# === Бот 1: Content Scout — @homelab_scout_bot ===
# RSS-парсер + наблюдение через HTTP (Prometheus, TLS) — без спецправ
SCOUT_BOT_TOKEN=ВПИШИ_ТОКЕН
SCOUT_CHAT_ID=ВПИШИ_CHAT_ID
SCOUT_CHECK_INTERVAL_MINUTES=60

# --- перевод статей на русский (deep-translator / Google Translate, БЕЗ ИИ и LLM) ---
# сначала шлётся перевод (🇷🇺), затем оригинал (🇬🇧). Русскоязычные источники (Habr) не переводятся.
TRANSLATE_ENABLED=true
TRANSLATE_MAX_CHARS=4000

# --- простаивающие ресурсы (Prometheus) ---
PROMETHEUS_URL=http://192.168.5.100:9090
WASTE_CHECK_INTERVAL_HOURS=168
WASTE_LOOKBACK=30d
WASTE_CPU_IDLE_THRESHOLD_PCT=2
WASTE_MIN_MEM_MB=100

# --- сертификаты (TLS-хендшейк, без спецправ) ---
CERT_CHECK_INTERVAL_HOURS=24
CERT_WARN_DAYS=14
# формат: host:port,host2:port2 (порт по умолчанию 443)
CERT_TARGETS=

# --- SLA / аптайм (Prometheus 'up' метрика) ---
SLA_CHECK_INTERVAL_HOURS=168
SLA_LOOKBACK=30d
SLA_WARN_PCT=99.0

# --- прогноз заполнения дисков (линейная регрессия по тренду, node_exporter) ---
FORECAST_CHECK_INTERVAL_HOURS=24
FORECAST_LOOKBACK_DAYS=14
FORECAST_WARN_DAYS=30

# === Бот 2: Sentry Ops — @lab_sentry_bot ===
# Всё, что требует повышенных прав: raw network scan + SSH к нодам
SCANNER_BOT_TOKEN=ВПИШИ_ТОКЕН
SCANNER_CHAT_ID=ВПИШИ_CHAT_ID

# --- сеть/безопасность ---
SCANNER_SUBNET=192.168.5.0/24
SCANNER_SCAN_INTERVAL_HOURS=6
SCANNER_NUCLEI_SEVERITY=critical,high,medium
# OLLAMA_HOST/OLLAMA_MODEL — опционально, только для человекочитаемых объяснений находок Nuclei в sentry-ops.
# Если не нужно — оставь пустыми, findings будут приходить без объяснений (не критично).
OLLAMA_HOST=http://192.168.5.104:11434
OLLAMA_MODEL=qwen2.5:3b

# --- бэкапы (заполни хотя бы одно, иначе /backup будет молчать) ---
BACKUP_CHECK_INTERVAL_HOURS=168
MINIO_ENDPOINT=192.168.5.102:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=backups
MINIO_SECURE=false
DUPLICATI_URL=

# --- docker bloat + config drift (нужен SSH-доступ ко всем нодам) ---
BLOAT_CHECK_INTERVAL_HOURS=168
CLUSTER_SSH_USER=admin1
CLUSTER_NODES=192.168.5.100:srv1,192.168.5.101:sand-box,192.168.5.102:host-196,192.168.5.104:hren-znaet,192.168.5.164:new-node,192.168.5.225:setevoipc
# путь к приватному SSH-ключу НА ХОСТЕ (не в контейнере), тот же что для passwordless-доступа с srv1
SSH_KEY_HOST_PATH=/home/admin1/.ssh/id_rsa

DRIFT_CHECK_INTERVAL_HOURS=24
# формат: host|/путь/к/файлу,host2|/путь/к/файлу2
DRIFT_WATCH_PATHS=

# --- on-call эскалация: критичные алерты требуют подтверждения (кнопка) ---
ESCALATION_MINUTES=30
ESCALATION_CHECK_MINUTES=10

# --- blast radius: анализ docker-compose файлов (depends_on + общие сети) ---
# формат: host|/путь/к/docker-compose.yml,host2|/путь2/docker-compose.yml
COMPOSE_PATHS=
