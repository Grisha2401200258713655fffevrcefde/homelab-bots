# === Бот 1: Content Scout (парсер статей/видео) ===
SCOUT_BOT_TOKEN=123456:AA...        # токен от @BotFather (можно тот же бот, что и ниже, но лучше отдельный)
SCOUT_CHAT_ID=123456789             # твой chat_id или id канала
SCOUT_CHECK_INTERVAL_MINUTES=60

# === Бот 2: Security Scanner (nmap + nuclei) ===
SCANNER_BOT_TOKEN=123456:BB...      # токен второго бота
SCANNER_CHAT_ID=123456789
SCANNER_SUBNET=192.168.5.0/24
SCANNER_SCAN_INTERVAL_HOURS=6
SCANNER_NUCLEI_SEVERITY=critical,high,medium

# Ollama (опционально, для human-readable объяснений находок сканера)
OLLAMA_HOST=http://192.168.5.104:11434
OLLAMA_MODEL=qwen2.5:3b

# === Бот 3: Backup Verify (реальный restore-тест) ===
BACKUP_BOT_TOKEN=
BACKUP_CHAT_ID=
BACKUP_CHECK_INTERVAL_HOURS=168
# MinIO (если бэкапы там)
MINIO_ENDPOINT=192.168.5.102:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=backups
MINIO_SECURE=false
# Duplicati (если используешь его — статус-проверка, не полный restore-тест)
DUPLICATI_URL=
DUPLICATI_PASSWORD=

# === Бот 4: Resource Waste (простаивающие контейнеры) ===
WASTE_BOT_TOKEN=
WASTE_CHAT_ID=
PROMETHEUS_URL=http://192.168.5.100:9090
WASTE_CHECK_INTERVAL_HOURS=168
WASTE_LOOKBACK=30d
WASTE_CPU_IDLE_THRESHOLD_PCT=2
WASTE_MIN_MEM_MB=100

# === Бот 5: Docker Bloat (SSH по нодам) ===
BLOAT_BOT_TOKEN=
BLOAT_CHAT_ID=
BLOAT_CHECK_INTERVAL_HOURS=168

# === Общее для ботов с SSH-доступом (docker-bloat, config-drift) ===
CLUSTER_SSH_USER=admin1
CLUSTER_NODES=192.168.5.100:srv1,192.168.5.101:sand-box,192.168.5.102:host-196,192.168.5.104:hren-znaet,192.168.5.164:new-node,192.168.5.225:setevoipc
# путь к твоему приватному SSH-ключу НА ХОСТЕ (не в контейнере)
SSH_KEY_HOST_PATH=/home/admin1/.ssh/id_rsa

# === Бот 6: Cert/Domain Expiry ===
CERT_BOT_TOKEN=
CERT_CHAT_ID=
CERT_CHECK_INTERVAL_HOURS=24
CERT_WARN_DAYS=14
# формат: host:port,host2:port2 (порт по умолчанию 443)
CERT_TARGETS=

# === Бот 7: Config Drift ===
DRIFT_BOT_TOKEN=
DRIFT_CHAT_ID=
DRIFT_CHECK_INTERVAL_HOURS=24
# формат: host|/путь/к/файлу,host2|/путь/к/файлу2
DRIFT_WATCH_PATHS=
